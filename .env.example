# ==================================================================
# DO NOT commit this file to version control
# Copy to .env and fill in all values before running
# ==================================================================

# ── Application ──────────────────────────────────────────────────
APP_NAME=aethera-ai
APP_TITLE=Aethera AI
APP_ENV=production                       # development | staging | production
APP_DEBUG=false
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
APP_URL=https://rcm.aetherahealthcare.com
FRONTEND_URL=https://rcm.aetherahealthcare.com

# ── Database (PostgreSQL) ────────────────────────────────────────
# Points to the postgres Docker container named "postgres"
DATABASE_URL=postgresql+asyncpg://aethera:password@postgres:5432/aethera_db
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────────────
# Points to the redis Docker container named "redis"
REDIS_URL=redis://redis:6379/0           # DB 0 — general / token blacklist
REDIS_CACHE_DB=1                         # DB 1 — application cache
REDIS_CELERY_DB=2                        # DB 2 — Celery task queue
REDIS_MFA_DB=3                           # DB 3 — MFA challenge store (5-min TTL)

# ── Celery ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false           # Set true for unit tests only
CELERY_WORKER_CONCURRENCY=8

# ── Vector Database (Qdrant) ─────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                          # Required if Qdrant is configured with API key auth
QDRANT_COLLECTION_CODING_GUIDELINES=icd10_guidelines
QDRANT_COLLECTION_PAYER_POLICIES=payer_policies
QDRANT_COLLECTION_APPEAL_TEMPLATES=appeal_templates

# ── AI / LLM (Ollama Cloud) ──────────────────────────────────────
# Get API key from https://ollama.com → account settings → API keys
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen3-coder:480b-cloud      # Primary model (large, high accuracy)
OLLAMA_FALLBACK_MODEL=deepseek-v3.1:671-cloud  # Fallback if primary fails
OLLAMA_TEMPERATURE=0.1                   # Low temperature for medical accuracy
OLLAMA_TIMEOUT=120                       # Seconds — large models need headroom
OLLAMA_MAX_RETRIES=3

# ── Embeddings (VoyageAI) ────────────────────────────────────────
# VoyageAI is the default embedding provider for RAG
# Get API key from https://www.voyageai.com
EMBEDDING_PROVIDER=voyageai
VOYAGEAI_API_KEY=                        # Required for RAG/vector search
VOYAGEAI_MODEL=voyage-large-2
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024

# ── Object Storage (S3 / MinIO) ─────────────────────────────────
# For local dev: points to MinIO container; for production: use AWS S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=aethera-documents
S3_BUCKET_ERA_FILES=aethera-era-files
S3_BUCKET_APPEALS=aethera-appeals
S3_BUCKET_AUDIT_ARCHIVE=aethera-audit-archive
S3_REGION=us-east-1
S3_ENCRYPTION=AES256

# ── Authentication / JWT ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
MFA_ISSUER=Aethera AI
MFA_BACKUP_CODES_COUNT=10
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
SESSION_TIMEOUT_MINUTES=15               # HIPAA: idle session cutoff

# ── Encryption ───────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHI_ENCRYPTION_KEY=                      # AES-256 Fernet key for PHI fields
FIELD_ENCRYPTION_KEY=                    # Separate key for field-level encryption

# ── Cloudflare Tunnel ─────────────────────────────────────────────
# Get from Cloudflare Zero Trust dashboard → Access → Tunnels
TUNNEL_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://rcm.aetherahealthcare.com

# ── EDI / Clearinghouse ─────────────────────────────────────────
CLEARINGHOUSE_PROVIDER=availity          # availity | change_healthcare | trizetto
CLEARINGHOUSE_API_URL=
CLEARINGHOUSE_API_KEY=
CLEARINGHOUSE_SENDER_ID=
CLEARINGHOUSE_RECEIVER_ID=
EDI_INTERCHANGE_SENDER_ID=
EDI_INTERCHANGE_RECEIVER_ID=

# ── FHIR / EHR Integration ───────────────────────────────────────
FHIR_SERVER_URL=
FHIR_AUTH_TYPE=oauth2                    # oauth2 | basic | token
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_SCOPE=patient/*.read encounter/*.read

# ── HIPAA / Compliance ──────────────────────────────────────────
AUDIT_LOG_RETENTION_YEARS=7
PHI_REDACTION_ENABLED=true
MINIMUM_NECESSARY_ENFORCEMENT=true

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=                              # Optional — leave empty to disable
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json                          # json for production, text for development

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_AI_ENDPOINTS=60/minute
RATE_LIMIT_BULK_OPERATIONS=20/minute
