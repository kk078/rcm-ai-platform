# ==================================================================
# MedClaim AI — Environment Configuration
# Copy to .env and fill in values before running
# ==================================================================

# ── Application ──────────────────────────────────────────────────
APP_NAME=medclaim-ai
APP_ENV=development                    # development, staging, production
APP_DEBUG=true
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://medclaim:password@localhost:5432/medclaim_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1
REDIS_CELERY_DB=2

# ── Celery ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false         # Set true for testing

# ── Vector Database (Qdrant) ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_CODING_GUIDELINES=icd10_guidelines
QDRANT_COLLECTION_PAYER_POLICIES=payer_policies
QDRANT_COLLECTION_APPEAL_TEMPLATES=appeal_templates

# ── AI / LLM (Ollama Cloud) ──────────────────────────────────────
OLLAMA_API_KEY=                         # Get from https://ollama.com → account settings → API keys
OLLAMA_MODEL=qwen3-coder:480b-cloud
OLLAMA_FALLBACK_MODEL=deepseek-v3.1:671-cloud
OLLAMA_TEMPERATURE=0.1                  # Low temp for medical accuracy

# ── Embeddings ───────────────────────────────────────────────────
EMBEDDING_PROVIDER=voyageai             # voyageai or openai
VOYAGEAI_API_KEY=
VOYAGEAI_MODEL=voyage-large-2
OPENAI_API_KEY=                         # Only if using OpenAI embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024

# ── Object Storage (S3 / MinIO) ─────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=medclaim-documents
S3_BUCKET_ERA_FILES=medclaim-era-files
S3_BUCKET_APPEALS=medclaim-appeals
S3_BUCKET_AUDIT_ARCHIVE=medclaim-audit-archive
S3_REGION=us-east-1
S3_ENCRYPTION=AES256

# ── Authentication ───────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_ANOTHER_RANDOM_STRING
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
MFA_ISSUER=MedClaim AI
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ── EDI / Clearinghouse ─────────────────────────────────────────
CLEARINGHOUSE_PROVIDER=availity         # availity, change_healthcare, trizetto
CLEARINGHOUSE_API_URL=
CLEARINGHOUSE_API_KEY=
CLEARINGHOUSE_SENDER_ID=
CLEARINGHOUSE_RECEIVER_ID=
EDI_INTERCHANGE_SENDER_ID=
EDI_INTERCHANGE_RECEIVER_ID=

# ── FHIR / EHR ──────────────────────────────────────────────────
FHIR_SERVER_URL=
FHIR_AUTH_TYPE=oauth2                   # oauth2, basic, token
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_SCOPE=patient/*.read encounter/*.read

# ── Encryption ───────────────────────────────────────────────────
PHI_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_KEY   # AES-256 key for PHI fields
FIELD_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_KEY  # Separate key for field-level encryption

# ── HIPAA / Compliance ──────────────────────────────────────────
AUDIT_LOG_RETENTION_YEARS=7
SESSION_TIMEOUT_MINUTES=15
PHI_REDACTION_ENABLED=true
MINIMUM_NECESSARY_ENFORCEMENT=true

# ── Monitoring ───────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json                         # json for production, text for development

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AI_ENDPOINTS=30/minute
RATE_LIMIT_BULK_OPERATIONS=10/minute
